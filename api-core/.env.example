# Puerto para el servidor backend
PORT=5001

# URL de conexión de MongoDB.
#
# ▸ Con Docker (recomendado): NO necesitas tocar esto. docker-compose.yml ya
#   define MONGO_URI=mongodb://mongo:27017/ReelScoreDB apuntando al contenedor
#   local de Mongo, y ese valor tiene prioridad sobre este archivo.
#
# ▸ Sin Docker (correr `node server.js` a mano): usa una de estas opciones:
#     Local:  mongodb://localhost:27017/ReelScoreDB
#     Atlas:  mongodb+srv://<usuario>:<password>@<cluster>/ReelScoreDB?retryWrites=true&w=majority
MONGO_URI="mongodb://localhost:27017/ReelScoreDB"

# Clave secreta para firmar los JSON Web Tokens (JWT)
# Puede ser cualquier frase larga y aleatoria
JWT_SECRET="tu_frase_secreta_muy_larga_para_firmar_tokens"

# API Key obtenida desde TMDB (The Movie Database)
TMDB_API_KEY="tu_api_key_de_tmdb"

# API Key para Google Gemini (Búsqueda Semántica por embeddings)
GEMINI_API_KEY="tu_api_key_de_gemini"

# --- Búsqueda semántica (embeddings) ---
# Genera los vectores del catálogo al arrancar (incremental, solo lo nuevo).
# AUTO_EMBED_CATALOG="true"
# Modelo de embeddings de Gemini.
# GEMINI_EMBED_MODEL="text-embedding-004"
# Umbral de similitud coseno (0-1) para considerar un título relevante.
# SEMANTIC_MIN_SIMILARITY="0.55"
# Máximo de resultados devueltos por búsqueda.
# SEMANTIC_MAX_RESULTS="24"

# --- Matcher de archive.org (fuentes de streaming) ---
# Relevancia mínima de título (0-1) para aceptar una fuente. Más bajo = más
# resultados pero más riesgo de falsos positivos.
# ARCHIVE_MATCH_MIN_RELEVANCE="0.6"
# Candidatos a revisar por título.
# ARCHIVE_MATCH_ROWS="12"
